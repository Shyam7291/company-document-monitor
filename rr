    if (!mobileNumber) {
      return "+91 XXXXX XXXXX";
    }

    return `+91 ${mobileNumber.slice(0, 5)} ${mobileNumber.slice(5, 10)}`;
  }, [mobileNumber]);

  const handleMobileChange = (value) => {
    if (isNumberLocked) {
      return;
    }

    const digitsOnly = value.replace(/\D/g, "").slice(0, 10);

    setMobileNumber(digitsOnly);
    setOtp("");
    setOtpVisible(false);
  };

