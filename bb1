            {!otpVisible ? (
  <button
  type="button"
  disabled={
    !isMobileValid || isCheckingNumber
  }
  onClick={handleNext}
  onMouseEnter={() =>
    setHoveredButton("next")
  }
  onMouseLeave={() =>
    setHoveredButton(null)
  }
  style={{
    ...styles.primaryBtn,

    ...(isMobileValid && !isCheckingNumber
      ? styles.primaryActive
      : styles.primaryDisabled),

    transform:
      hoveredButton === "next" &&
      isMobileValid &&
      !isCheckingNumber
        ? "translateY(-3px) scale(1.015)"
        : "none",
  }}
>
  {isCheckingNumber
    ? "Scanning Number..."
    : "Next"}
</button>
) : (
  <>
    
  <button
  type="button"
  disabled={!isOtpValid || isVerifying}
  onClick={handleVerifyAndSignIn}
  onMouseEnter={() =>
    setHoveredButton("verify")
  }
  onMouseLeave={() =>
    setHoveredButton(null)
  }
  style={{
    ...styles.primaryBtn,
    ...(isOtpValid && !isVerifying
      ? styles.primaryActive
      : styles.primaryDisabled),

    transform:
      hoveredButton === "verify" &&
      isOtpValid &&
      !isVerifying
        ? "translateY(-3px) scale(1.015)"
        : "none",
  }}
>
  {isVerifying
    ? "Verifying..."
    : "Verify & Sign In"}

</button>
  </>
)}

            <div style={styles.createAccountRow}>
