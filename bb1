import React, { useEffect, useMemo, useState } from "react";
import {
  requestBuyerOtp,
  verifyBuyerOtp,
} from "../api/authApi";

export default function FinalSignInOTPPageWithChangeMobileNumber
({
  goToPage1,
  goToPage2,
  goToPage4,
}) {

  const viewport = useViewport();

  const styles = useMemo(
    () => createStyles(viewport),
    [viewport.width, viewport.height]
  );

  const [mobileNumber, setMobileNumber] = useState("");
  const [otp, setOtp] = useState("");
  const [otpVisible, setOtpVisible] = useState(false);
  const [focusedField, setFocusedField] = useState(null);
  const [hoveredButton, setHoveredButton] = useState(null);

  const isMobileValid = mobileNumber.length === 10;
  const isOtpValid = otp.length === 6;
  const isNumberLocked = otpVisible;
  const [loginError, setLoginError] = useState("");
  const [isVerifying, setIsVerifying] = useState(false);
  const [showErrorPopup, setShowErrorPopup] =
  useState(false);

const [popupMessage, setPopupMessage] =
  useState("");

const [popupTitle, setPopupTitle] =
  useState("");

const [popupType, setPopupType] =
  useState("mobile");

const [isCheckingNumber, setIsCheckingNumber] =
  useState(false);


  const formattedNumber = useMemo(() => {
    if (!mobileNumber) {
      return "+91 XXXXX XXXXX";
    }

    return `+91 ${mobileNumber.slice(0, 5)} ${mobileNumber.slice(5, 10)}`;
  }, [mobileNumber]);

  const handleMobileChange = (value) => {
    if (isNumberLocked) {
      return;
    }
  
    const digitsOnly = value
      .replace(/\D/g, "")
      .slice(0, 10);
  
    setMobileNumber(digitsOnly);
    setOtp("");
    setOtpVisible(false);
    setLoginError("");
    setPopupMessage("");
    setShowErrorPopup(false);
  };
  const handleOtpChange = (value) => {
    const digitsOnly = value.replace(/\D/g, "").slice(0, 6);
    setOtp(digitsOnly);
  };

  const handleNext = async () => {
    if (!isMobileValid || isCheckingNumber) {
      return;
    }
  
    setLoginError("");
    setPopupMessage("");
    setPopupTitle("");
    setShowErrorPopup(false);
    setIsCheckingNumber(true);
  
    try {
      const result = await requestBuyerOtp({
        phone: mobileNumber,
      });
  
      if (!result.success) {
        setPopupType("mobile");
        setPopupTitle("Number not recognized");
  
        setPopupMessage(
          result.message ||
            "This mobile number is not registered."
        );
  
        setShowErrorPopup(true);
        return;
      }
  
      setOtp("");
      setOtpVisible(true);
      setFocusedField("otp");
    } catch (error) {
      console.error(
        "Mobile number check failed:",
        error
      );
  
      setPopupType("mobile");
      setPopupTitle("Unable to check number");
  
      setPopupMessage(
        "Unable to check this mobile number. Please try again."
      );
  
      setShowErrorPopup(true);
    } finally {
      setIsCheckingNumber(false);
    }
  };

  const handleChangeNumber = () => {
    setOtpVisible(false);
    setOtp("");
    setLoginError("");
    setPopupMessage("");
    setShowErrorPopup(false);
    setFocusedField("mobile");
  };
  const handleVerifyAndSignIn = async () => {
    if (
      !isMobileValid ||
      !isOtpValid ||
      isVerifying
    ) {
      return;
    }
  
    setLoginError("");
    setPopupMessage("");
    setPopupTitle("");
    setShowErrorPopup(false);
    setIsVerifying(true);
  
    try {
      const result = await verifyBuyerOtp({
        phone: mobileNumber,
        otp: otp,
      });
  
      if (!result.success) {
        setPopupType("otp");
  
        setPopupTitle(
          result.code === "OTP_MISMATCH"
            ? "Incorrect OTP"
            : "Verification failed"
        );
  
        setPopupMessage(
          result.message ||
            "The OTP entered is incorrect. Please try again."
        );
  
        setShowErrorPopup(true);
        return;
      }
  
      goToPage4?.();
    } catch (error) {
      console.error(
        "OTP verification failed:",
        error
      );
  
      setPopupType("otp");
      setPopupTitle("Verification unavailable");
  
      setPopupMessage(
        "Unable to verify the OTP. Please try again."
      );
  
      setShowErrorPopup(true);
    } finally {
      setIsVerifying(false);
    }
  };
  
  
  return (
    <div style={styles.page}>
      <div style={styles.phone}>
        <section style={styles.hero}>
          <div style={styles.glowOne} />
          <div style={styles.glowTwo} />
          <div style={styles.gridOverlay} />

          <nav style={styles.nav}>
            <div style={styles.brandWrap}>
              <div style={styles.logo}>🪨</div>

              <div style={styles.brandText}>
                <p style={styles.brandName}>StoneRate</p>
                <p style={styles.brandSub}>Secure OTP Login</p>
              </div>
            </div>

            <button
  type="button"
  style={styles.backBtn}
  onClick={goToPage1}
>
  Back
</button>
          </nav>

          <div style={styles.heroText}>
            <p style={styles.kicker}>SIGN IN</p>

            <h1 style={styles.title}>Verify your mobile number</h1>

            <p style={styles.subtitle}>
              Enter your number to receive OTP and continue to your account.
            </p>
          </div>

          <div style={styles.visualStage}>
            <div style={styles.orbitOne} />
            <div style={styles.orbitTwo} />

            <div
              style={{
                ...styles.loginCard3d,
                ...(isMobileValid ? styles.loginCardReady : {}),
              }}
            >
              <div style={styles.topHandle} />

              <div style={styles.cardHeaderRow}>
                <div
                  style={{
                    ...styles.lockBox,
                    background: isMobileValid ? "#22c55e" : "#f59e0b",
                  }}
                >
                  {isNumberLocked ? "🔒" : isMobileValid ? "✅" : "🔐"}
                </div>

                <div style={styles.statusPill}>
                  {isNumberLocked
                    ? "Locked"
                    : isMobileValid
                    ? "Ready"
                    : "Waiting"}
                </div>
              </div>

              <div style={styles.numberPanel}>
                <p style={styles.panelLabel}>Mobile Number</p>
                <p style={styles.panelNumber}>{formattedNumber}</p>
              </div>

              <div style={styles.readyPanel}>
                <span
                  style={{
                    ...styles.statusDot,
                    background: isMobileValid ? "#22c55e" : "#f59e0b",
                  }}
                />

                <div style={styles.readyText}>
                  <p style={styles.readyTitle}>
                    {isMobileValid ? "Ready for OTP" : "Enter 10 digits"}
                  </p>

                  <p style={styles.readySub}>
                    {otpVisible
                      ? "Mobile number locked"
                      : "OTP appears after Next"}
                  </p>
                </div>
              </div>
            </div>

            <div
              style={{
                ...styles.floatBadgeTop,
                color: isMobileValid ? "#15803d" : "#92400e",
              }}
            >
              +91 India
            </div>

            <div
              style={{
                ...styles.floatBadgeLeft,
                borderColor: isMobileValid ? "#22c55e" : "#f59e0b",
              }}
            >
              OTP Login
            </div>

            <div
              style={{
                ...styles.floatIcon,
                background: isMobileValid ? "#22c55e" : "#f59e0b",
              }}
            >
              📲
            </div>
          </div>
        </section>

        <section style={styles.formSection}>
          <div style={styles.formCard}>
            <div style={styles.formTitleRow}>
              <div style={styles.formHeadingText}>
                <p style={styles.formKicker}>MOBILE VERIFICATION</p>
                <h2 style={styles.formTitle}>Sign In</h2>
              </div>

              <div
                style={{
                  ...styles.formIcon,
                  background: isMobileValid ? "#22c55e" : "#1c1917",
                }}
              >
                {isNumberLocked ? "🔒" : isMobileValid ? "✓" : "🔐"}
              </div>
            </div>

            <div style={styles.fieldBlock}>
              <label style={styles.label}>Mobile Number</label>

              <div
                style={{
                  ...styles.mobileWrap,
                  ...(focusedField === "mobile"
                    ? styles.fieldFocused
                    : {}),
                  ...(isNumberLocked
                    ? styles.mobileWrapLocked
                    : {}),
                }}
              >
                <div
