  >
    <div
      style={styles.popupCard}
      role="alertdialog"
      aria-modal="true"
      aria-labelledby="error-popup-title"
      aria-describedby="error-popup-message"
    >
      <div style={styles.popupGrid} />
      <div style={styles.popupGlowOne} />
      <div style={styles.popupGlowTwo} />
      <div style={styles.popupScannerLine} />

      <button
        type="button"
        aria-label="Close error popup"
        style={styles.popupCloseButton}
        onClick={() => {
          setShowErrorPopup(false);

          setFocusedField(
            popupType === "otp"
              ? "otp"
              : "mobile"
          );
        }}
      >
        ×
      </button>

      <div style={styles.popupIconOuter}>
        <div style={styles.popupIconInner}>
          !
        </div>
      </div>

      <p style={styles.popupKicker}>
        {popupType === "otp"
          ? "OTP SCAN FAILED"
          : "IDENTITY SCAN FAILED"}
      </p>

      <h3
        id="error-popup-title"
        style={styles.popupTitle}
      >
        {popupTitle}
      </h3>

      <p
        id="error-popup-message"
        style={styles.popupMessage}
      >
        {popupMessage}
      </p>

      <div style={styles.popupNumberPanel}>
        <span style={styles.popupNumberLabel}>
          {popupType === "otp"
            ? "VERIFICATION STATUS"
            : "SCANNED MOBILE NUMBER"}
        </span>

        {popupType === "otp" ? (
          <>
            <div style={styles.popupOtpDots}>
              {[0, 1, 2, 3, 4, 5].map(
                (index) => (
                  <span
                    key={index}
                    style={styles.popupOtpDot}
                  />
                )
              )}
            </div>

            <span style={styles.popupStatus}>
              OTP DOES NOT MATCH
            </span>
          </>
        ) : (
          <>
            <strong style={styles.popupNumber}>
              {formattedNumber}
            </strong>

            <span style={styles.popupStatus}>
              ACCOUNT NOT LOCATED
            </span>
          </>
        )}
      </div>

      <button
        type="button"
        style={styles.popupActionButton}
        onClick={() => {
          setShowErrorPopup(false);
          setPopupMessage("");
          setPopupTitle("");

          if (popupType === "otp") {
            setOtp("");
            setFocusedField("otp");
          } else {
            setFocusedField("mobile");
          }
        }}
      >
        {popupType === "otp"
          ? "ENTER OTP AGAIN"
          : "EDIT MOBILE NUMBER"}
      </button>

      {popupType === "mobile" && (
        <button
          type="button"
          style={styles.popupCreateButton}
          onClick={() => {
            setShowErrorPopup(false);
            goToPage2?.();
          }}
        >
          Create a new buyer account
        </button>
      )}
    </div>
  </div>
)}
    </div>
  );
}

function useViewport() {
  const [viewport, setViewport] = useState({
    width:
      typeof window !== "undefined"
        ? window.innerWidth
        : 390,
    height:
      typeof window !== "undefined"
        ? window.innerHeight
        : 844,
  });

  useEffect(() => {
    const updateViewport = () => {
      setViewport({
        width: window.innerWidth,
        height: window.innerHeight,
      });
    };

    updateViewport();

    window.addEventListener("resize", updateViewport);

    return () => {
      window.removeEventListener("resize", updateViewport);
    };
  }, []);

  return viewport;
}

