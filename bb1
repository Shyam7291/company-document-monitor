    New to StoneRate?
  </span>

  <button
    type="button"
    style={styles.createAccountLink}
    onClick={goToPage2}
  >
    Create Account
  </button>
</div>
          </div>
          </section>
      </div>

      {showErrorPopup && (
  <div
    style={styles.popupOverlay}
    role="presentation"
    onMouseDown={(event) => {
      if (event.target === event.currentTarget) {
        setShowErrorPopup(false);
      }
