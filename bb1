                    ...(isNumberLocked
                      ? styles.mobileInputLocked
                      : {}),
                  }}
                />

                <div
                  style={{
                    ...styles.inputStatus,
                    background: isMobileValid
                      ? "#22c55e"
                      : "#e7e5e4",
                    color: isMobileValid ? "#ffffff" : "#57534e",
                  }}
                >
                  {isNumberLocked
                    ? "🔒"
                    : isMobileValid
                    ? "✓"
                    : mobileNumber.length}
                </div>
              </div>

              <div style={styles.mobileHelperRow}>
